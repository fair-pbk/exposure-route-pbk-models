			style="filled,rounded"];
	}
	AAbsComp -> APV	[label=_J0,
		minlen=1];
	APV -> ALiver	[label=_J1];
	ALiver -> ALiverMet	[label=_J5,
		minlen=1];
	ALiver -> ASysComp	[label=_J4];
	ASysComp -> APV	[label=_J2];
	ASysComp -> ALiver	[label=_J3];
	ASysComp -> ARenalEx	[label=_J6,
