digraph {
	graph [ratio=fill,
		size="7,4"
	];
	node [fontname=Arial];
	subgraph cluster_Gut {
		graph [color=black,
			fillcolor=lightblue,
			fontname=Arial,
			href="#compartment-Gut",
			label="Gut
[-]",
			shape=box,
			style="filled,rounded"
		];
		AGut	[color=black,
			fillcolor=gold,
			href="#species-AGut",
			label="AGut
[-]",
			shape=box,
			style="filled,rounded"];
	}
	subgraph cluster_Blood {
		graph [color=black,
			fillcolor=lightblue,
			fontname=Arial,
			href="#compartment-Blood",
			label="Blood
[-]",
			shape=box,
			style="filled,rounded"
		];
		ABlood	[color=black,
			fillcolor=gold,
			href="#species-ABlood",
			label="ABlood
[-]",
			shape=box,
			style="filled,rounded"];
		ABloodMetTotal	[color=black,
			fillcolor=gold,
			href="#species-ABloodMetTotal",
			label="ABloodMetTotal
[-]",
			shape=box,
			style="filled,rounded"];
	}
	subgraph cluster_Rest {
		graph [color=black,
			fillcolor=lightblue,
			fontname=Arial,
			href="#compartment-Rest",
			label="Rest
[-]",
			shape=box,
			style="filled,rounded"
		];
		ARest	[color=black,
			fillcolor=gold,
			href="#species-ARest",
			label="ARest
[-]",
			shape=box,
			style="filled,rounded"];
	}
	AGut -> ABlood	[label=_J0,
		minlen=1];
	ABlood -> ABloodMetTotal	[label=_J3,
		minlen=1];
	ABlood -> ARest	[label=_J1];
	ARest -> ABlood	[label=_J2];
}
