model Zwartsen_2025_Chlorpyrifos_Human()

#Created: Carolina Vogs, January 2026
#Checked: 

model notes ```
Chlorpyrifos PBK (Zwartsen et al 2025):
```
model description "https://doi.org/10.14573/altex.2412051"


#------------------------
# Body size & base volumes
#------------------------
BW   = 70                       # kg
VLc  = 0.0257                   # L/kg (liver)
VBloodc  = 0.074                # L/kg (Blood); sum of arterial and venous blood

VL   := VLc*BW                  # L
VBlood := VBloodc*BW           	# L

VRest := 0.84*BW - VL - VBlood   # Lumped Rest-of-body volume L 

#------------------------
# Blood Flows
#------------------------
QC    := 15*BW^0.74             # L/h (cardiac output)
QLc   = 0.227
	
QL    := QLc*QC                # L/h (liver)

QRest := (1 - QLc )*QC         # L/h (rest)

#------------------------
# Absorption & hepatic metabolism
#------------------------
Fa = 0.35                       # average fraction from literature

Free = 0.021                    # unbound fraction in plasma
ksto 	 = 5.23755e-6           # 1/h stomach lumen -> Intestinal lumen
kabsSL   = 0.97718              # 1/h
kabsIL   = 0.978132             # 1/h 

fup = 0.021
#------------------------
# Hepatic metabolism - biochemical parameters
#------------------------

CYP1_Abundance = 52 	# CYP1A2 abundance (pmolCYP/mg protein) (calculated based on database in Simcyp; sum of EM, PM and UM)
CYP2_Abundance = 15.8 	# CYP2B6 abundance (pmolCYP/mg protein) (calculated based on database in Simcyp; sum of EM, PM and UM)
CYP3_Abundance = 5.4 	# CYP2C19 abundance (pmolCYP/mg protein)(calculated based on database in Simcyp; sum of EM, PM and UM)
CYP4_Abundance = 137 	# CYP3A4 abundance (pmolCYP/mg protein) (calculated based on database in Simcyp; sum of EM, PM and UM)

SFCYP1	= 0.072         # Scaling factor CYP1A2 ISEF (Vmax) (non compound-specific) (Zhao et al., 2022)
SFCYP2	= 0.476         # Scaling factor CYP2B6 ISEF (Vmax) (non compound-specific) (Zhao et al., 2022)
SFCYP3	= 0.209         # Scaling factor CYP2C19 ISEF (Vmax)(non compound-specific)(Zhao et al., 2022)
SFCYP4	= 0.107         # Scaling factor CYP3A4 ISEF (Vmax) (non compound-specific) (Zhao et al., 2022)
MPL = 32                # Scaling factor of human liver microsome in mg to gram liver (mg microsomal protein /g liver) (Al-Malahmeh, A. J et al., 2017) (Barter et al., 2007)

#------------------------
# Hepatic metabolism - Michaelis-Menten Kinetic - Pathway 1
#------------------------

# to CPFoxon by CYP1A2
KmLMet1_CYP1  = 0.61            # µM
VmaxLMet1_CYP1C = 3.963         # pmol/min/pmol CYP
VmaxLMet1_CYP1 := VmaxLMet1_CYP1C * SFCYP1 * CYP1_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to CPFoxon by CYP2B6
KmLMet1_CYP2  = 0.14            # µM
VmaxLMet1_CYP2C = 7.755         # pmol/min/pmol CYP
VmaxLMet1_CYP2 := VmaxLMet1_CYP2C * SFCYP2 * CYP2_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to CPFoxon by CYP2C19
KmLMet1_CYP3  = 1.89                      							   # µM
VmaxLMet1_CYP3C = 2.744	   									   # pmol/min/pmol CYP
VmaxLMet1_CYP3 := VmaxLMet1_CYP3C * SFCYP3 * CYP3_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to CPFoxon by CYP3A4
KmLMet1_CYP4  = 29.77                     							   # µM
VmaxLMet1_CYP4C = 17.78   									   # pmol/min/pmol CYP
VmaxLMet1_CYP4 := VmaxLMet1_CYP4C * SFCYP4 * CYP4_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)


#------------------------
# Hepatic metabolism - Michaelis-Menten Kinetic - Pathway 2
#------------------------

# to TCPy by CYP1A2
KmLMet2_CYP1  = 1.25                      							   # µM
VmaxLMet2_CYP1C = 2.957	   									   # pmol/min/pmol CYP
VmaxLMet2_CYP1 := VmaxLMet2_CYP1C * SFCYP1 * CYP1_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to TCPy by CYP2B6
KmLMet2_CYP2  = 1.28                     							   # µM
VmaxLMet2_CYP2C = 5.492	   									   # pmol/min/pmol CYP
VmaxLMet2_CYP2 := VmaxLMet2_CYP2C * SFCYP2 * CYP2_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to TCPy by CYP2C19
KmLMet2_CYP3  = 1.37                     							   # µM
VmaxLMet2_CYP3C = 17.51   									   # pmol/min/pmol CYP
VmaxLMet2_CYP3 := VmaxLMet2_CYP3C * SFCYP3 * CYP3_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)

# to TCPy by CYP3A4
KmLMet2_CYP4  = 18.13                    							   # µM
VmaxLMet2_CYP4C = 23.86  									   # pmol/min/pmol CYP
VmaxLMet2_CYP4 := VmaxLMet2_CYP4C * SFCYP4 * CYP4_Abundance/(1000000 * 60 * MPL * VL * 1000)	   # µmol/h/kg liver; VmaxLMet/(1000*60*32*1000)
        
 

#------------------------
# Partition coefficients
#------------------------
BPR = 1.3				# Blood to plasma ratio
PL := 26.07 * BPR                       # Liver
PRest = 1                               # Rest body

#------------------------
# Compartments (sizes)
#------------------------
compartment StomachLumen; StomachLumen = 1
compartment IntestineLumen; IntestineLumen = 1
compartment Liver;   Liver = VL
compartment Blood;  Blood = VBlood
compartment Rest;    Rest  = VRest
 

#------------------------
# Species (amount states)
#------------------------
substanceOnly species ASL in StomachLumen
substanceOnly species AIL in IntestineLumen
substanceOnly species ALiver in Liver
substanceOnly species ABlood in Blood
substanceOnly species ARest  in Rest

# Met1 = Chlorpyrifosoxon, Met2 = TCPy
substanceOnly species ALiverMet1  in Liver
substanceOnly species ALiverMet2  in Liver


#------------------------
# Initial conditions
#------------------------
ASL = 0;
ALL = 0;
ALiver = 0; 
ABlood = 0; 
ARest = 0; 
ALiverMet1  = 0; 
ALiverMet2  = 0; 

#------------------------
# Concentrations 
#------------------------
CLiver := ALiver / Liver
CBlood := ABlood / Blood
CBlood_Total := CBlood/fup
CRest  := ARest  / Rest

#------------------------
# Reactions / Transfers
#------------------------

# GI absorption
ASL -> AIL;     ksto * ASL
ASL -> ALiver;  kabsSL * ASL
AIL -> ALiver;  kabsIL * AIL

# Perfusion-limited exchanges (blood <-> liver & rest)

ABlood   -> ALiver;     QL * CBlood * fup
ALiver   -> ABlood;     QL * CLiver/PL

ABlood   -> ARest;     QRest * CBlood * fup
ARest  	 -> ABlood;     QRest * CRest/PRest

# Hepatic Metabolism

ALiver -> ALiverMet1;  VmaxLMet1_CYP1 * (CLiver/PL) / ((CLiver/PL) + KmLMet1_CYP1)  +  VmaxLMet1_CYP2 * (CLiver/PL) / ((CLiver/PL) + KmLMet1_CYP2) + VmaxLMet1_CYP3 * (CLiver/PL) / ((CLiver/PL) + KmLMet1_CYP3) + VmaxLMet1_CYP4 * (CLiver/PL) / ((CLiver/PL) + KmLMet1_CYP4)      

ALiver -> ALiverMet2;  VmaxLMet2_CYP1 * (CLiver/PL) / ((CLiver/PL) + KmLMet2_CYP1)  +  VmaxLMet2_CYP2 * (CLiver/PL) / ((CLiver/PL) + KmLMet2_CYP2) + VmaxLMet2_CYP3 * (CLiver/PL) / ((CLiver/PL) + KmLMet2_CYP3) + VmaxLMet2_CYP4 * (CLiver/PL) / ((CLiver/PL) + KmLMet2_CYP4)     




end
